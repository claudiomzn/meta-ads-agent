generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  // Redefinição de senha via token
  passwordResetToken  String?
  passwordResetExpiry DateTime?

  // Marca o momento da última troca de senha.
  // Tokens emitidos ANTES desta data são considerados inválidos (revogados).
  passwordChangedAt DateTime?

  // Identidade unificada: id do usuário no Supabase (login principal do AdsGenius)
  supabaseUserId String? @unique

  // Estúdio de Criativos: controle de cota de artes geradas.
  // Trial: contador vitalício (limite único durante o período de teste).
  // Pro/Agência: contador mensal, resetado quando creativeGenerationsMonth muda.
  creativeGenerationsUsed  Int     @default(0)
  creativeGenerationsMonth String?

  mcpConnection MCPConnection?
}

model Campaign {
  id        String @id @default(cuid())
  userId    String
  name      String
  product   String
  objective String
  budget    Float
  status    String @default("draft")

  // Integração Meta
  metaCampaignId  String?   @unique
  metaAdAccountId String?
  metaStatus      String?
  publishedAt     DateTime?
  lastSyncAt      DateTime?

  // Métricas sincronizadas do Meta
  metaSpend       Float?
  metaImpressions Int?
  metaClicks      Int?
  metaConversions Int?
  metaRoas        Float?
  metaCpc         Float?
  metaCpl         Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  copies    Copy[]
  audiences Audience[]
  briefs    CreativeBrief[]
  abTests   ABTest[]
  adSets    AdSet[]
}

model AdSet {
  id               String   @id @default(cuid())
  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name             String
  dailyBudget      Float
  targeting        String
  optimizationGoal String

  // Público-alvo salvo (opcional)
  audienceId String?
  audience   Audience? @relation(fields: [audienceId], references: [id], onDelete: SetNull)

  // Meta IDs
  metaAdSetId String? @unique
  metaStatus  String?

  // Métricas
  metaSpend     Float?
  metaRoas      Float?
  metaCpl       Float?
  metaFrequency Float?

  ads       Ad[]
  createdAt DateTime @default(now())
}

model Ad {
  id      String @id @default(cuid())
  adSetId String
  adSet   AdSet  @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  name    String

  headline       String
  bodyText       String
  cta            String
  imageUrl       String?
  videoUrl       String?
  destinationUrl String?

  // Meta IDs
  metaAdId       String? @unique
  metaStatus     String?
  metaCreativeId String?

  // Métricas
  metaCtr   Float?
  metaCpc   Float?
  metaSpend Float?

  createdAt DateTime @default(now())
}

model MCPConnection {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaAccessToken String
  adAccountIds    String
  connected       Boolean   @default(false)
  lastConnectedAt DateTime?
  expiresAt       DateTime?
  mcpUrl          String?
  mcpProvider     String? // meta / pipeboard / zapier
  metaPixelId     String?
  createdAt       DateTime  @default(now())
}

model SyncLog {
  id        String   @id @default(cuid())
  userId    String   @default("") // retrocompatível — registros antigos ficam com ""
  type      String
  status    String
  details   String?
  duration  Int?
  createdAt DateTime @default(now())
}

model AutomationRule {
  id          String    @id @default(cuid())
  userId      String
  name        String
  campaignId  String?
  targetId    String
  targetType  String
  trigger     String
  condition   String
  value       Float
  window      Int
  action      String
  alertEmail  String?
  active      Boolean   @default(true)
  lastChecked DateTime?
  createdAt   DateTime  @default(now())

  logs RuleLog[]
}

model RuleLog {
  id         String         @id @default(cuid())
  ruleId     String
  rule       AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  action     String
  metrics    String?
  executedAt DateTime       @default(now())
}

model Copy {
  id         String    @id @default(cuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId     String
  format     String
  framework  String
  headline   String
  body       String
  cta        String
  score      Int?
  favorite   Boolean   @default(false)
  createdAt  DateTime  @default(now())
}

// Criativo arquivado no Estúdio de Criativos (copy + arte gerada + briefing)
model StudioCreative {
  id            String   @id @default(cuid())
  userId        String
  framework     String
  headline      String
  body          String
  cta           String
  visualConcept String?
  imagePrompt   String?
  imageUrl      String? // URL durável (Supabase Storage) ou do fal como fallback
  aspect        String   @default("1:1")
  product       String?
  niche         String?
  objective     String?
  favorite      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Audience {
  id             String    @id @default(cuid())
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId         String
  name           String
  interests      String
  behaviors      String?
  ageMin         Int
  ageMax         Int
  gender         String
  locations      String
  estimatedSize  Int?
  metaAudienceId String?
  createdAt      DateTime  @default(now())

  adSets AdSet[]
}

model CreativeBrief {
  id               String    @id @default(cuid())
  campaignId       String?
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId           String
  concept          String
  midjourneyPrompt String?
  palette          String
  dimensions       String
  elements         String
  createdAt        DateTime  @default(now())
}

model ABTest {
  id         String    @id @default(cuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId     String
  name       String
  hypothesis String
  variable   String
  variantA   String
  variantB   String
  budget     Float
  duration   Int
  metric     String
  status     String    @default("running")
  winner     String?
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  details    String?
  ip         String?
  createdAt  DateTime @default(now())
}

model CampaignInsight {
  id             String   @id @default(cuid())
  userId         String
  type           String // 'full_analysis' | 'suggestion'
  title          String
  summary        String
  content        String // JSON completo da análise
  campaignsCount Int      @default(0)
  createdAt      DateTime @default(now())
}

model CreativeAnalysis {
  id                     String   @id @default(cuid())
  userId                 String
  adId                   String?
  campaignId             String?
  adAccountId            String?
  filePath               String
  fileType               String
  fileName               String
  copyHeadline           String?
  copyBody               String?
  copyCta                String?
  overallScore           Float
  approvalRecommendation String
  approvalReason         String
  summary                String
  criteriaScores         String
  formatScores           String
  strengths              String
  improvements           String
  realCtr                Float?
  realCpl                Float?
  realRoas               Float?
  realImpressions        Int?
  isComparison           Boolean  @default(false)
  comparedWithId         String?
  comparisonWinner       String?
  comparisonDetails      String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Histórico de mensagens do chat com o Agente IA
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // 'user' | 'assistant'
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Proposta gerada pelo agente noturno (scan automático de madrugada) —
// o usuário aprova ou rejeita com 1 clique; aprovar executa a ação no Meta.
model AgentProposal {
  id               String    @id @default(cuid())
  userId           String
  type             String
  title            String
  description      String
  payload          String // JSON
  estimatedSavings Float     @default(0)
  status           String    @default("pending") // pending | approved | rejected | executed | failed
  result           String?
  createdAt        DateTime  @default(now())
  decidedAt        DateTime?
  executedAt       DateTime?

  @@index([userId, status])
}

// Snapshot diário de métricas agregadas de todas as campanhas do usuário.
// Gravado a cada sync (cron de 1h). Usado para o gráfico do dashboard.
model DailyMetric {
  id              String   @id @default(cuid())
  userId          String
  date            String // YYYY-MM-DD
  spend           Float    @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  activeCampaigns Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([userId, date])
}

// ── Qualificação de Leads via WhatsApp (IA) ──────────────────────────────────
// Config por cliente do bot de qualificação. Maior parte pode ser auto-preenchida
// a partir da análise de site que o AdsGenius já faz.
model WhatsappConfig {
  id     String @id @default(cuid())
  userId String @unique

  enabled Boolean @default(false)

  // Contexto do negócio (alimenta o system prompt do bot)
  businessName  String
  product       String
  differentials String?
  region        String?
  tone          String  @default("amigável e profissional")

  // Perguntas de qualificação (JSON: array de strings) e critério de "qualificado"
  questions         Json   @default("[]")
  qualifiedCriteria String @default("Respondeu às perguntas de qualificação")
  maxQuestions      Int    @default(4)
  maxBotMessages    Int    @default(8)

  // Handoff e atendimento
  handoffContact String? // número/identificador do vendedor humano
  businessHours  String? // ex: "Seg-Sex 8-18h"

  // Transporte (agnóstico): "evolution" | "meta" | "none"
  transport       String @default("none")
  transportConfig Json   @default("{}") // chaves específicas do transporte (instanceName, phoneId, etc.)

  // Vínculo com a conversão do Google Ads / Meta (para disparar ao iniciar conversa)
  conversionId    String? // AW-XXXXX
  conversionLabel String?

  // ── Limite diário e saldo pré-pago (modelo sem dívida) ──────────────────────
  // As primeiras N conversas NOVAS de cada dia são grátis. Esgotada a franquia,
  // o bot consome de prepaidMessagesRemaining (1 mensagem = dailyOverageCentsPerMsg
  // centavos já PAGOS). Se o saldo chegar a zero, o bot FICA MUDO (não responde)
  // até uma recarga de rechargeAmountCents ser efetivamente paga no Asaas — nunca
  // responde "fiado". O saldo só é creditado pelo webhook de pagamento confirmado.
  dailyFreeConversations   Int @default(12)
  dailyOverageCentsPerMsg  Int @default(15)
  rechargeAmountCents      Int @default(2000) // R$20,00 por recarga
  prepaidMessagesRemaining Int @default(0)

  // Dados de faturamento (Asaas exige CPF/CNPJ para criar o cliente) e o id do
  // cliente já criado no Asaas (criado sob demanda, na 1ª cobrança).
  billingCpfCnpj  String?
  asaasCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cobranças de recarga geradas no Asaas — histórico + controle para nunca
// gerar duas cobranças em aberto ao mesmo tempo, e para o webhook saber
// quantas mensagens creditar quando o pagamento for confirmado.
model WhatsappCharge {
  id              String   @id @default(cuid())
  userId          String
  amountCents     Int
  messagesGranted Int // quantas mensagens esta recarga libera quando PAGA
  asaasPaymentId  String   @unique
  invoiceUrl      String
  status          String   @default("PENDING") // PENDING | PAID | FAILED
  // Truque de índice único parcial: só recebe o userId enquanto status=PENDING
  // (zera pra null em qualquer outra transição). Postgres permite múltiplos
  // NULLs num índice único, então isso garante "no máximo 1 PENDING por
  // usuário" garantido pelo PRÓPRIO BANCO — fecha a corrida em que duas
  // mensagens concorrentes viam "sem cobrança aberta" ao mesmo tempo e cada
  // uma criava a sua.
  pendingUserId   String?  @unique
  createdAt       DateTime @default(now())

  @@index([userId, status])
}

// Estado de cada conversa de lead (uma por número de telefone, por usuário).
model WhatsappConversation {
  id        String @id @default(cuid())
  userId    String
  leadPhone String // número do lead (E.164 ou id do WhatsApp)

  state          String  @default("greeting") // greeting | qualifying | qualified | cold | handoff | closed
  label          String? // QUENTE | FRIO | SEM_RESPOSTA
  questionsAsked Int     @default(0)
  botMessages    Int     @default(0)

  history         Json    @default("[]") // [{role:'user'|'assistant', text, at}]
  summary         String? // resumo de 1 linha gerado para o vendedor
  conversionFired Boolean @default(false)
  capiLeadFired   Boolean @default(false) // evento Lead (Meta CAPI) já enviado p/ este lead

  // Marcada na criação: true se esta conversa nasceu depois de já ter batido o
  // limite diário de conversas grátis do usuário — cada mensagem do bot aqui
  // dentro conta no acumulado de excedente (ver WhatsappConfig).
  billable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, leadPhone])
  @@index([userId, state])
}
