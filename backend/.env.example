# ─────────────────────────────────────────────────────────────────────────────
# META ADS AGENT — Variáveis de Ambiente do Backend
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# ─── Banco de dados ───────────────────────────────────────────────────────────
# SQLite para desenvolvimento. Para produção, troque por PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/meta_ads_agent"
DATABASE_URL="file:./dev.db"

# ─── Segurança ────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Gere com: openssl rand -base64 32
JWT_SECRET="cole-aqui-uma-chave-aleatoria-com-minimo-32-chars!!"

# Exatamente 32 caracteres. Usado para criptografar tokens Meta com AES-256.
# Gere com: openssl rand -base64 24
ENCRYPTION_KEY="cole-aqui-chave-de-exatamente-32!!"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# URL do frontend (usada no CORS). Em produção, troque pelo domínio real.
FRONTEND_URL="http://localhost:5173"

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Chave da API Anthropic para geração de copies, planos e alertas com IA.
# Obtenha em: https://console.anthropic.com/settings/keys
# Deixe vazio para desativar funções de IA (app funciona sem ela).
ANTHROPIC_API_KEY=""

# ─── Meta MCP ─────────────────────────────────────────────────────────────────
# URL do servidor MCP usado para executar ações no Meta Ads.
# Escolha UMA das opções abaixo:

# Opção 1 — Pipeboard (recomendado para começar, plano gratuito disponível)
# Cadastro: https://pipeboard.co
META_MCP_URL="https://meta-ads.mcp.pipeboard.co/"

# Opção 2 — Zapier MCP (requer plano pago Zapier)
# META_MCP_URL="https://mcp.zapier.com/api/mcp/s/SEU_ID/mcp"

# Opção 3 — Meta Oficial (requer app aprovado no Meta Business)
# META_MCP_URL="https://graph.facebook.com/mcp"


# ─── Meta Webhook ─────────────────────────────────────────────────────────────
# Token de verificação do webhook (você define, qualquer string aleatória).
# Configure o mesmo valor no painel do Meta Developers em:
# App > Webhooks > Verify Token
META_WEBHOOK_VERIFY_TOKEN="define-um-token-aleatorio-aqui"

# App Secret do seu app Meta (encontrado em App > Configurações > Básico).
# Usado para validar assinatura HMAC-SHA256 dos eventos do webhook.
# Obtenha em: https://developers.facebook.com/apps
META_APP_SECRET=""

# ─── Email (alertas) ──────────────────────────────────────────────────────────
# SMTP usado para enviar emails (reset de senha, boas-vindas, alertas).
# Pode usar o SMTP do Resend (smtp.resend.com, porta 587, user "resend", pass = API key).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AdsGenius <relatorio@adsgenius.net>"

# Email do admin que recebe alertas quando a sincronização Meta falha 2x seguidas
# para o mesmo usuário (possível problema no Pipeboard/MCP).
ADMIN_ALERT_EMAIL=""

# ─── WhatsApp gerenciado (Evolution API central) ──────────────────────────────
# Evolution API do AdsGenius (deploy: repo evolution-render no Render).
# Com estas 3 variáveis, o cliente conecta o WhatsApp com 1 clique + QR code.
EVOLUTION_URL=""
EVOLUTION_API_KEY=""
# URL pública DESTE backend (para a Evolution entregar os webhooks de mensagem)
PUBLIC_URL="https://meta-ads-agent-backend.onrender.com"
